[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/vinhtuong294/mappingui2303.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
[branch "Mapping-UI-2"]
	vscode-merge-base = origin/main
	remote = origin
	merge = refs/heads/Mapping-UI-2
[remote "done-demo"]
	url = https://github.com/vinhtuong7749/Done-demo.git
	fetch = +refs/heads/*:refs/remotes/done-demo/*
[branch "demo"]
	vscode-merge-base = origin/Mapping-UI-2
	remote = origin
	merge = refs/heads/demo
